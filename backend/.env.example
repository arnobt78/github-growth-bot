# Local Postgres connection string. Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<db>
# For local dev, create the DB once (e.g. `createdb github_growth_bot`) then run
# `alembic upgrade head` to apply migrations.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/github_growth_bot

# Static bearer token every backend endpoint (except /api/health) requires.
# Generate your own random value — do not use "change-me" outside local dev:
#   openssl rand -base64 32
# MUST be the exact same value as frontend/.env.local's BACKEND_API_KEY — the
# frontend's Route Handlers send this as `Authorization: Bearer <API_KEY>` on
# every server-to-server call. A mismatch silently 401s every request.
API_KEY=change-me

# --- LLM provider keys (all optional — LLMRouter tries each in order and
# degrades gracefully to "no AI recommendations today" if every provider is
# unset/rate-limited; the pipeline's raw metrics still work with zero keys set) ---
# Groq: https://console.groq.com/keys
GROQ_API_KEY=
# Google AI Studio (Gemini): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# OpenRouter: https://openrouter.ai/keys (uses the free ":free" model tier)
OPENROUTER_API_KEY=
# Hugging Face: https://huggingface.co/settings/tokens (a "Read" token is enough)
HUGGINGFACE_API_KEY=
# Cloudflare Workers AI: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_KEY=
# Cloudflare account id: found on the right sidebar of any Cloudflare dashboard page
CLOUDFLARE_ACCOUNT_ID=
# Vercel AI Gateway: https://vercel.com/docs/ai-gateway → your project's API key
VERCEL_AI_GATEWAY_KEY=

# JSON array of allowed frontend origins for CORS. Local dev frontend runs on
# :3000 by default (`npm run dev` in frontend/); add your production Vercel
# domain here too once deployed, e.g. ["http://localhost:3000", "https://your-app.vercel.app"].
CORS_ORIGINS=["http://localhost:3000"]

# Must be a Fernet key (output of `Fernet.generate_key()` — Python `cryptography`
# package), not an arbitrary string. Used to encrypt/decrypt stored GitHub OAuth
# tokens; a non-Fernet value crashes on the very first sign-in's token encryption.
# Generate one: `.venv/bin/python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
TOKEN_ENCRYPTION_KEY=

# HMAC shared secret — MUST be the exact same value here and in
# frontend/.env.local.example's INTERNAL_AUTH_SECRET. This backend and the
# frontend each independently sign/verify the internal per-user auth token; a
# mismatch causes every authenticated request to silently 401 with no
# indication that the two secrets disagree. Generate one: `openssl rand -base64 32`
INTERNAL_AUTH_SECRET=

# --- Phase 4E: Notifications & alerting (all optional — if unset, alert
# emails silently never send; no error, no crash) ---
# Resend: https://resend.com/api-keys (free tier is generous for personal-SaaS volume)
RESEND_API_KEY=
# Must be a sender address verified on your Resend account/domain, e.g.
# "GitHub Growth <alerts@yourdomain.com>". Using an unverified domain causes
# every send to fail (EmailClient degrades to "no email sent," not a crash).
EMAIL_FROM=
# Your deployed frontend's base URL, used to build the "View" button link in
# alert emails, e.g. https://your-app.vercel.app (no trailing slash).
FRONTEND_BASE_URL=
