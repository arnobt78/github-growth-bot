DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/github_growth_bot
API_KEY=change-me
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
VERCEL_AI_GATEWAY_KEY=
CORS_ORIGINS=["http://localhost:3001"]

# Must be a Fernet key (output of `Fernet.generate_key()` — Python `cryptography`
# package), not an arbitrary string. Used to encrypt/decrypt stored GitHub OAuth
# tokens; a non-Fernet value crashes on the very first sign-in's token encryption.
TOKEN_ENCRYPTION_KEY=

# HMAC shared secret — MUST be the exact same value here and in
# frontend/.env.local.example's INTERNAL_AUTH_SECRET. This backend and the
# frontend each independently sign/verify the internal per-user auth token; a
# mismatch causes every authenticated request to silently 401 with no
# indication that the two secrets disagree.
INTERNAL_AUTH_SECRET=
