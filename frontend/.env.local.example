# URL of the locally-running (or deployed) FastAPI backend.
BACKEND_URL=http://localhost:8000
# Must be the exact same value as the backend's API_KEY (backend/.env.example)
# — sent as the Bearer token on every backend call. A mismatch causes every
# request from this frontend to silently 401 against the backend.
# Generate your own random value (then copy it into backend/.env too):
#   openssl rand -base64 32
BACKEND_API_KEY=change-me

# Auth.js's own session-cookie signing/encryption secret (unrelated to the
# GitHub OAuth app and unrelated to INTERNAL_AUTH_SECRET below — this one is
# frontend-only, never shared with the backend). Generate one:
#   openssl rand -base64 32
AUTH_SECRET=

# From your GitHub OAuth App (GitHub → Settings → Developer settings → OAuth
# Apps → New OAuth App, or https://github.com/settings/developers):
#   Homepage URL:              http://localhost:3000 (or your production domain)
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
#                               (production: https://<your-domain>/api/auth/callback/github)
# GitHub OAuth Apps support exactly ONE callback URL each — register a SEPARATE
# OAuth App for production with its own callback URL/credentials; don't try to
# reuse the dev app's Client ID/Secret in production.
# AUTH_GITHUB_ID is the "Client ID" shown immediately after registering.
AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET is generated via the "Generate a new client secret" button
# on the app's settings page — shown only once, copy it immediately.
AUTH_GITHUB_SECRET=

# HMAC shared secret — MUST be the exact same value here and in the backend's
# INTERNAL_AUTH_SECRET (backend/.env.example). Used to sign/verify the internal
# per-user auth token on every proxied request; a mismatch causes every
# authenticated request to silently 401 with no indication the two secrets
# disagree. Generate one (then copy it into backend/.env too):
#   openssl rand -base64 32
INTERNAL_AUTH_SECRET=
